# StockTrack Production Environment Configuration
# This is an EXAMPLE file. Copy to .env and fill in your values if needed.
# Do NOT commit .env to GitHub - it may contain secrets!

# ═══════════════════════════════════════════════════════════════════════════
# STREAMLIT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_LOGGER_LEVEL=info

# Session state (optional: adjust based on performance)
STREAMLIT_CLIENT_MAX_MESSAGE_SIZE=200

# Theme (optional)
# STREAMLIT_THEME_BASE=light
# STREAMLIT_THEME_PRIMARY_COLOR=#FF6B6B


# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (Optional - mostly for future multi-tenant setup)
# ═══════════════════════════════════════════════════════════════════════════

# Database file path (default: stock_tracker.db in app root)
# DATABASE_URL=sqlite:///app/data/stock_tracker.db

# Connection timeout (seconds)
# DATABASE_TIMEOUT=5


# ═══════════════════════════════════════════════════════════════════════════
# BACKUP CONFIGURATION (Optional - for cloud backup setup)
# ═══════════════════════════════════════════════════════════════════════════

# Enable cloud backups to DigitalOcean Spaces or AWS S3
ENABLE_CLOUD_BACKUP=false

# DigitalOcean Spaces Configuration (fill if using cloud backups)
# SPACES_KEY=your_spaces_access_key
# SPACES_SECRET=your_spaces_secret_key
# SPACES_REGION=nyc3
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_BUCKET=stocktrack-backups

# AWS S3 Configuration (alternative to Spaces)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_S3_BUCKET=stocktrack-backups
# AWS_S3_REGION=us-east-1


# ═══════════════════════════════════════════════════════════════════════════
# LOGGING & MONITORING (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Papertrail Log Aggregation (optional)
# PAPERTRAIL_API_TOKEN=your_papertrail_token

# Custom log file path
# LOG_FILE_PATH=/app/logs/stocktrack.log


# ═══════════════════════════════════════════════════════════════════════════
# SECURITY (Optional - for future enhancement)
# ═══════════════════════════════════════════════════════════════════════════

# HTTPS enforcement
# SECURE_SSL_REDIRECT=true

# CORS configuration
# ALLOWED_ORIGINS=stocktrack.yourcompany.com,www.stocktrack.yourcompany.com

# Session timeout (minutes)
# SESSION_TIMEOUT=480


# ═══════════════════════════════════════════════════════════════════════════
# NOTE: FOR PRODUCTION USE
# ═══════════════════════════════════════════════════════════════════════════
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values in .env
# 3. Add .env to .gitignore (keep secrets out of GitHub)
# 4. In DigitalOcean App Platform:
#    - Store sensitive values as "Secrets" in app settings
#    - Reference them with ${VARIABLE_NAME}
#
# NEVER commit passwords, API keys, or tokens to GitHub!
